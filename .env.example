# =============================================================================
# GHG Tool / Carbontrace — environment variables
# =============================================================================
#
# Copy this file to `.env` and fill in the values that apply to your
# deployment.  docker-compose reads `.env` automatically; for systemd or
# bare-metal launches export the variables before starting the API and
# Streamlit processes.
#
# DO NOT commit `.env` to git (already in .gitignore).
# =============================================================================


# -----------------------------------------------------------------------------
# Environment selector — controls demo mode, /docs visibility, log verbosity.
# -----------------------------------------------------------------------------
#
# Allowed values:
#   - production  (default)   No demo seed, no demo user, no /docs Swagger UI,
#                             JWT secret enforced.  Safe for real data.
#   - development             Auto-enables demo seed + demo/demo login + sticky
#                             "DEMO MODE" banner.  /docs and /redoc exposed.
#                             Use ONLY on developer laptops.
#   - demo                    Same as development but the banner is more
#                             prominent (used for client-facing demos).
#   - test                    Internal: CI test profile.  Do not use otherwise.
#
GHG_ENVIRONMENT=production


# -----------------------------------------------------------------------------
# Demo mode explicit opt-in (legacy; superseded by GHG_ENVIRONMENT).
# -----------------------------------------------------------------------------
#
# Leave unset or set to `false` in production.  Setting `true` here is
# IGNORED when GHG_ENVIRONMENT=production (production wins, hard block).
#
# GHG_DEMO_MODE=false


# -----------------------------------------------------------------------------
# Database password — Postgres user `ghg_app`.
# -----------------------------------------------------------------------------
#
# REQUIRED.  docker-compose now refuses to start without it (no `changeme`
# fallback).  Generate a strong password, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
#
POSTGRES_PASSWORD=please-replace-with-a-strong-postgres-password


# -----------------------------------------------------------------------------
# JWT signing secret — minimum 32 characters.
# -----------------------------------------------------------------------------
#
# Generate a fresh secret per environment, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# REQUIRED in production.  Startup aborts if missing or < 32 chars.
#
GHG_JWT_SECRET=please-replace-with-a-real-secret-min-32-characters-long


# -----------------------------------------------------------------------------
# CORS origins — comma-separated list of allowed front-end origins.
# -----------------------------------------------------------------------------
#
# Production example:
#   GHG_CORS_ORIGINS=https://carbontrace.gresmalt.it
#
# Local dev (Streamlit on localhost:8501):
#   GHG_CORS_ORIGINS=http://localhost:8501
#
GHG_CORS_ORIGINS=http://localhost:8501


# -----------------------------------------------------------------------------
# Log level — DEBUG | INFO | WARNING | ERROR
# -----------------------------------------------------------------------------
GHG_LOG_LEVEL=INFO


# -----------------------------------------------------------------------------
# Company branding (optional overrides; defaults are Gresmalt-specific).
# -----------------------------------------------------------------------------
#
# GHG_PRODUCT_NAME=Carbontrace
# GHG_COMPANY_NAME=Gruppo Ceramiche Gresmalt S.p.A.
# GHG_COMPANY_SHORT=Gresmalt
# GHG_TENANT_CODE=GRESMALT

# Dashboard identifier (previously hardcoded as "esg-main-2026").
# Default is "carbontrace". Override to tag your deployment instance.
# GHG_DASHBOARD_ID=carbontrace

# Known production sites — comma-separated site codes.
# Default: the 7 Gresmalt sites (IANO, VIANO, VIANO_GARGOLA, CASALGRANDE,
#          FIORANO, SASSUOLO, FRASSINORO).
# The API also exposes GET /api/v1/sites which reads ref.sites from the DB
# and is the preferred source; this env var is a UI fallback for offline /
# pre-migration scenarios.
# GHG_SITES=IANO,VIANO,CASALGRANDE


# -----------------------------------------------------------------------------
# Bootstrap admin persistence between rebuilds (optional).
#
# When the three variables below are all set AND ref.users is empty at startup,
# a single admin user is inserted automatically (idempotent — safe to leave set
# after first run).  This survives `docker compose down -v` + re-up without
# manual `python -m scripts.create_admin` runs.
#
# How to generate the bcrypt hash:
#   python -m scripts.create_admin --print-hash-only
#   (prompts for the password interactively, prints only the $2b$12$... hash)
#
# NEVER store the plaintext password here.  The hash is safe to commit ONLY in
# private / air-gapped repositories; treat it as a medium-sensitivity secret.
#
# GHG_BOOTSTRAP_ADMIN_USERNAME=marco.vacchi@gresmalt.it
# GHG_BOOTSTRAP_ADMIN_EMAIL=marco.vacchi@gresmalt.it
# GHG_BOOTSTRAP_ADMIN_PASSWORD_HASH=$2b$12$...


# =============================================================================
# Quick-switch recipes
# =============================================================================
#
# Turn ON demo mode (preloaded data + demo/demo login):
#   GHG_ENVIRONMENT=development
#   # optional, redundant if ENV is development:
#   # GHG_DEMO_MODE=true
#
# Turn OFF demo mode (current default):
#   GHG_ENVIRONMENT=production
#   # GHG_DEMO_MODE leave unset or =false
#
# Restart API + Streamlit for changes to take effect.
# =============================================================================
