# Coverage configuration for wave 2 API unit tests.
# Overrides the pyproject.toml [tool.coverage.run] omit list to include the
# API and security layers now that they are implemented in wave 2.
# The data-engineer wave 1 pyproject.toml excluded these as "not yet built".
[run]
source = src/ghg_tool
omit =
    */tests/*
    */migrations/*
    src/ghg_tool/infrastructure/db/*
    src/ghg_tool/infrastructure/factors/*
    src/ghg_tool/infrastructure/reporting/*
    src/ghg_tool/infrastructure/etl/*
    src/ghg_tool/dashboard/*
    src/ghg_tool/etl/readers/*
    src/ghg_tool/etl/writers/*
    src/ghg_tool/etl/schemas/*
    src/ghg_tool/etl/orchestrator.py

[report]
fail_under = 85
show_missing = true
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    raise NotImplementedError
